# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/interview_system
# Supabase tip: `db.<project-ref>.supabase.co` is often IPv6-only.
# If you see host translation/DNS errors on local networks, use the Session/Transaction pooler URL
# from Dashboard -> Settings -> Database -> Connection string.
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_ECHO=False

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration (Token validation only - tokens created by external auth service)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256

# AI Service Configuration
# Choose one: gemini or openai
AI_SERVICE=gemini

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Configuration (alternative)
OPENAI_API_KEY=your-openai-api-key-here

# AWS S3 Configuration (for video clip storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=exam-proctoring-clips

# Or use local storage
USE_LOCAL_STORAGE=True
LOCAL_STORAGE_PATH=./storage/clips

# Application Configuration
APP_NAME=AI Interview Examination System
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Proctoring Configuration
FACE_DETECTION_INTERVAL=2.5
YAW_THRESHOLD=25
PITCH_THRESHOLD=20
INTEGRITY_PENALTY_FACTOR=2.5
INTEGRITY_TERMINATION_THRESHOLD=50
CLIP_DURATION=10

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
